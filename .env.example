# Database (for local development with docker-compose)
# For Render, use the managed PostgreSQL database URL provided by Render
DATABASE_URL=postgresql://app:change_me@localhost:5432/appdb

# Master key used to wrap data-encryption-keys (replace with a strong random value)
# For local testing only. In production use a secure KMS or vault.
MASTER_KEY=please_replace_with_32_byte_base64_or_hex

# Backend API URL (for frontend)
# Local development: http://localhost:8000
# Render: https://your-backend-service.onrender.com
BACKEND_URL=http://localhost:8000

# Frontend
REACT_APP_API_URL=http://localhost:8000
